APP_NAME=absensi
APP_ENV=development
APP_PORT=8080
APP_TIMEZONE=Asia/Jakarta

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=absensi
DB_SSLMODE=disable

JWT_ACCESS_SECRET=access-secret-change-me
JWT_REFRESH_SECRET=refresh-secret-change-me
